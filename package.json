{
  "name": "sepia",
  "version": "0.1.0",
  "description": "An open-source secure AI browser engine",
  "type": "module",
  "license": "MIT",
  "author": "Mohinish",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.12.3"
  },
  "bin": {
    "sepia": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/interfaces/sdk/index.js",
      "types": "./dist/interfaces/sdk/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fmt": "prettier --write \"**/*.{ts,mjs,json,md}\" --ignore-path .gitignore",
    "fmt:check": "prettier --check \"**/*.{ts,mjs,json,md}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "test:tokens": "vitest run tests/token-budget",
    "test:mutation": "vitest run tests/mutation",
    "test:fingerprint": "vitest run tests/fingerprint",
    "test:leak": "vitest run tests/cross-profile",
    "test:boundary": "vitest run tests/data-boundary",
    "test:resilience": "vitest run tests/resilience",
    "test:example": "vitest run tests/example",
    "dev": "tsx watch cli/index.ts",
    "security:audit": "pnpm audit --audit-level=critical"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "openai": "4.73.0",
    "playwright": "1.48.2"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "9.15.0",
    "prettier": "3.4.2",
    "tiktoken": "1.0.15",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "typescript-eslint": "8.17.0",
    "vitest": "3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
